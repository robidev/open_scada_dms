#mongodb
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root_secret
MONGO_USER_DB=scada
MONGO_USER_USERNAME=dbuser
MONGO_USER_PASSWORD="mongo_secret"
MONGO_REPLICA_SET_NAME=rs0

#redis
REDIS_PASSWORD="redis_secret"

#influxdb
INFLUXDB_DATA_ENGINE=tsm1
INFLUXDB_REPORTING_DISABLED=true
INFLUXD_LOG_LEVEL=error
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=administrator
DOCKER_INFLUXDB_INIT_ORG=scada
DOCKER_INFLUXDB_INIT_BUCKET=bucket_1
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN="influxdb_secret"

# grafana
GF_INSTALL_PLUGINS=
GF_LOG_LEVEL=error
